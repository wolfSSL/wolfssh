# vim:ft=automake
# All paths should be given relative to the root

if BUILD_EXAMPLE_SERVERS
noinst_PROGRAMS += examples/echoserver/echoserver
noinst_HEADERS += examples/echoserver/echoserver.h
examples_echoserver_echoserver_CPPFLAGS     =
if BUILD_SCP
examples_echoserver_echoserver_CPPFLAGS     += -DWOLFSSH_SCP
endif
if BUILD_SFTP
examples_echoserver_echoserver_CPPFLAGS     += -DWOLFSSH_SFTP
endif
if BUILD_SHELL
examples_echoserver_echoserver_CPPFLAGS     += -DWOLFSSH_SHELL
endif
if BUILD_AGENT
examples_echoserver_echoserver_CPPFLAGS     += -DWOLFSSH_AGENT
endif
if BUILD_FWD
examples_echoserver_echoserver_CPPFLAGS     += -DWOLFSSH_FWD
endif
examples_echoserver_echoserver_SOURCES      = examples/echoserver/echoserver.c
examples_echoserver_echoserver_LDADD        = src/libwolfssh.la
examples_echoserver_echoserver_DEPENDENCIES = src/libwolfssh.la
endif

DISTCLEANFILES+= examples/echoserver/.libs/echoserver
